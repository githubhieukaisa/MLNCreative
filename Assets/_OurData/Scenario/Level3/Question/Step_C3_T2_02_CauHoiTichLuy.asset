  m_Script: {fileID: 11500000, guid: dea60b411c9a18c4980249e287142770, type: 3}
  m_Name: Step_C3_T2_02_CauHoiTichLuy
  m_EditorClassIdentifier: Assembly-CSharp::QuestionStep
  questionText: "Nguy\xEAn l\xFD '\u0110\u1ED3ng ti\u1EC1n \u0111i li\u1EC1n kh\xFAc
    ru\u1ED9t'. B\u1EA1n s\u1EBD l\xE0m g\xEC v\u1EDBi s\u1ED1 l\u1EE3i nhu\u1EADn
    kh\u1ED5ng l\u1ED3 n\xE0y?"
  optionA:
    text: "T\u1EF1 th\u01B0\u1EDFng: L\u1EA5y to\xE0n b\u1ED9 ti\u1EC1n l\xE3i mua
      iPhone 16 Pro Max, \u0111i du l\u1ECBch ch\u1EEFa l\xE0nh, ng\xE0y mai l\u1EA1i
      ti\u1EBFp t\u1EE5c b\xE1n xe c\u0169 y nh\u01B0 th\xE1ng tr\u01B0\u1EDBc."
    capitalChange: -4000000
    brandChange: 40
    techChange: -10
    feedback: "B\u1EA1n tr\xF4ng th\u1EADt h\xE0o nho\xE1ng tr\xEAn m\u1EA1ng x\xE3
      h\u1ED9i, ai c\u0169ng ng\u01B0\u1EE1ng m\u1ED9. Nh\u01B0ng th\u1EF1c t\u1EBF,
      qu\u1EF9 d\u1EF1 ph\xF2ng c\u1EE7a b\u1EA1n \u0111\xE3 c\u1EA1n ki\u1EC7t.
      M\u1ECDi th\u1EE9 s\u1EAFp s\u1EE5p \u0111\u1ED5..."
    nextBranch: {fileID: 11400000, guid: 3c1f52d422dd235439a827a4345e8d1c, type: 2}
  optionB:
    text: "C\u1EA5t gi\u1EA5u cho an to\xE0n: Mua v\xE0ng nh\xE9t d\u01B0\u1EDBi
      g\u1EA7m gi\u01B0\u1EDDng, kh\xF4ng ti\xEAu x\xE0i, c\u0169ng kh\xF4ng \u0111\u1EA7u
      t\u01B0. C\u1EE9 \u0111\u1EC3 ti\u1EC1n ng\u1EE7 y\xEAn."
    capitalChange: 1000000
    brandChange: -30
    techChange: 0
    feedback: "Ti\u1EC1n c\u1EE7a b\u1EA1n r\u1EA5t an to\xE0n. Nh\u01B0ng chi\u1EBFc
      xe b\xE1nh m\xEC ng\xE0y c\xE0ng c\u0169 k\u1EF9, bong tr\xF3c. Kh\xE1ch h\xE0ng
      d\u1EA7n ng\xE1n ng\u1EA9m v\xE0 r\u1EDDi \u0111i..."
    nextBranch: {fileID: 11400000, guid: 454faa91a8beeb4469f17aa6c09df9f0, type: 2}
  optionC:
    text: "T\xEDch l\u0169y t\u01B0 b\u1EA3n: Tr\xEDch m\u1ED9t n\u1EEDa ti\u1EC1n
      \u0111\u1EC3 mua chi\u1EBFc xe b\xE1nh m\xEC th\u1EE9 2, thu\xEA th\xEAm sinh
      vi\xEAn \u0111\u1EC3 m\u1EDF r\u1ED9ng quy m\xF4. N\u1EEDa c\xF2n l\u1EA1i
      m\u1EDBi ti\xEAu x\xE0i."
    capitalChange: -2000000
    brandChange: 30
    techChange: 20
    feedback: "Ch\u1EA5p nh\u1EADn m\u1EA5t m\u1ED9t kho\u1EA3n v\u1ED1n l\u1EDBn
      l\xFAc \u0111\u1EA7u. Nh\u01B0ng \u0111\xE2y l\xE0 quy\u1EBFt \u0111\u1ECBnh
      \u0111\u1ED5i \u0111\u1EDDi! Doanh thu c\u1EE7a b\u1EA1n s\u1EBD nh\xE2n \u0111\xF4i
      trong th\xE1ng t\u1EDBi."
    nextBranch: {fileID: 0}
