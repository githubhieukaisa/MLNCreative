  m_Script: {fileID: 11500000, guid: e2eab4a3faaa6134d89cbb71d1d5a509, type: 3}
  m_Name: Thoai_C3_Outro
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "Xe b\xE1nh m\xEC th\u1EE9 2 \u0111i v\xE0o ho\u1EA1t \u0111\u1ED9ng.
      Doanh thu t\u0103ng theo c\u1EA5p s\u1ED1 nh\xE2n. B\u1EA1n ch\xEDnh th\u1EE9c
      m\u1EDF r\u1ED9ng \u0111\u1EBF ch\u1EBF \u0111\u1ED3 \u0103n v\u1EB7t c\u1EE7a
      m\xECnh."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 3631846501073772673, guid: bd8afe407bd522740a380887e33e45cd, type: 3}
      CharacterSprite: {fileID: 21300000, guid: f67a3ea10109c9c4dafc478eca3d914e, type: 2}
      CharacterAnimTrigger: 
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "Ch\xFAc m\u1EEBng! B\u1EA1n \u0111\xE3 n\u1EAFm v\u1EEFng b\xED m\u1EADt
      t\u1ED1i th\u01B0\u1EE3ng c\u1EE7a gi\u1EDBi t\u01B0 b\u1EA3n: Gi\xE1 tr\u1ECB
      th\u1EB7ng d\u01B0 v\xE0 T\xEDch l\u0169y t\u01B0 b\u1EA3n."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: 21300000, guid: f67a3ea10109c9c4dafc478eca3d914e, type: 2}
      CharacterAnimTrigger: 
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "T\u1EEB m\u1ED9t sinh vi\xEAn ngh\xE8o, b\u1EA1n \u0111\xE3 bi\u1EBFt
      c\xE1ch \xE1p d\u1EE5ng c\xF4ng ngh\u1EC7 \u0111\u1EC3 b\xF3c l\u1ED9t... \xE0
      nh\u1EA7m, s\u1EA3n xu\u1EA5t gi\xE1 tr\u1ECB th\u1EB7ng d\u01B0 t\u01B0\u01A1ng
      \u0111\u1ED1i, v\xE0 d\xF9ng ti\u1EC1n \u0111\u1EC3 m\u1EDF r\u1ED9ng quy m\xF4.
      H\xE3y chu\u1EA9n b\u1ECB v\u01B0\u01A1n ra bi\u1EC3n l\u1EDBn \u1EDF Ch\u01B0\u01A1ng
      4: \u0110\u1ED9c quy\u1EC1n v\xE0 H\u1ED9i nh\u1EADp!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: 21300000, guid: f67a3ea10109c9c4dafc478eca3d914e, type: 2}
      CharacterAnimTrigger: 
