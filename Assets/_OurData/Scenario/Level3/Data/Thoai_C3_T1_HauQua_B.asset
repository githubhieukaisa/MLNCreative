  m_Script: {fileID: 11500000, guid: e2eab4a3faaa6134d89cbb71d1d5a509, type: 3}
  m_Name: Thoai_C3_T1_HauQua_B
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: ed33b76932720524cb4a5f2fd6b50419, type: 2}
    content: "\xD4i ti\u1EC1n l\u01B0\u01A1ng th\xE1ng n\xE0y c\u1EE7a em nhi\u1EC1u
      qu\xE1! Anh/ch\u1ECB l\xE0 \xF4ng ch\u1EE7 tuy\u1EC7t v\u1EDDi nh\u1EA5t qu\u1EA3
      \u0111\u1EA5t! Em h\u1EE9a s\u1EBD l\xE0m \u1EDF \u0111\xE2y m\xE3i m\xE3i!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 3631846501073772673, guid: bd8afe407bd522740a380887e33e45cd, type: 3}
      CharacterSprite: {fileID: -8812602774031461341, guid: 2ccfe99c986fd96409e41071ef01f1d8, type: 3}
      CharacterAnimTrigger: Sparkle
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "Th\u1EA5y Nam vui m\xECnh c\u0169ng vui... \u1EDA khoan, m\xE1y n\u01B0\u1EDBng
      b\xE1nh m\xEC h\u1ECFng r\u1ED3i, m\xE0 m\xECnh \u0111\u01B0a h\u1EBFt ti\u1EC1n
      l\xE3i cho Nam r\u1ED3i, l\u1EA5y ti\u1EC1n \u0111\xE2u m\xE0 mua m\xE1y m\u1EDBi
      b\xE2y gi\u1EDD?"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 7288185362635543259, guid: 5c5b830189542d54d86a500885f28f7c, type: 3}
      CharacterSprite: {fileID: 7566863766233733025, guid: 119caf2d917709c4e8558ba73d0b7902, type: 3}
      CharacterAnimTrigger: Shock
