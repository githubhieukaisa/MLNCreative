  m_Script: {fileID: 11500000, guid: e2eab4a3faaa6134d89cbb71d1d5a509, type: 3}
  m_Name: Thoai_C3_T2_AnhCuong_B
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "Gi\u1EA5u ti\u1EC1n \u0111i th\xEC n\xF3 ch\u1EC9 l\xE0 \u0111\u1ED3ng
      ti\u1EC1n th\xF4ng th\u01B0\u1EDDng (H-T-H), k\u1EBFt th\xFAc \u1EDF vi\u1EC7c
      c\u1EA5t tr\u1EEF. N\xF3 gi\u1ED1ng nh\u01B0 c\u1EE5c s\u1EAFt v\xF4 tri v\u1EADy."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 1285922619873297232, guid: 38c26bda4219e7644acf35f8da6fda56, type: 3}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: Sigh
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "\u0110\u1ED3ng ti\u1EC1n c\u1EE7a em ph\u1EA3i l\xE0 T\u01B0 b\u1EA3n,
      v\u1EADn \u0111\u1ED9ng theo c\xF4ng th\u1EE9c T-H-T'. Em ph\u1EA3i th\u1EF1c
      hi\u1EC7n 'T\xEDch l\u0169y t\u01B0 b\u1EA3n' \u2013 bi\u1EBFn m\u1ED9t ph\u1EA7n
      l\u1EE3i nhu\u1EADn th\xE0nh t\u01B0 b\u1EA3n ph\u1EE5 th\xEAm \u0111\u1EC3
      't\xE1i s\u1EA3n xu\u1EA5t m\u1EDF r\u1ED9ng' (\u0111\u1EA7u t\u01B0 xe m\u1EDBi).
      H\xE3y \u0111\u1EC3 ti\u1EC1n \u0111\u1EBB ra ti\u1EC1n!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: 0}
      CharacterAnimTrigger: Shake
