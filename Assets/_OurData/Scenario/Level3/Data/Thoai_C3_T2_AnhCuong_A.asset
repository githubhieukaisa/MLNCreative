  m_Script: {fileID: 11500000, guid: e2eab4a3faaa6134d89cbb71d1d5a509, type: 3}
  m_Name: Thoai_C3_T2_AnhCuong_A
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "\u0102n ch\u01A1i \u0111\xE3 \u0111\u1EDDi ch\u01B0a em? Em l\u1EA5y
      h\u1EBFt gi\xE1 tr\u1ECB th\u1EB7ng d\u01B0 ra ti\xEAu x\xE0i c\xE1 nh\xE2n,
      \u0111\xF3 g\u1ECDi l\xE0 'T\xE1i s\u1EA3n xu\u1EA5t gi\u1EA3n \u0111\u01A1n'
      \u2013 l\u1EB7p l\u1EA1i qu\xE1 tr\xECnh s\u1EA3n xu\u1EA5t v\u1EDBi quy m\xF4
      nh\u01B0 c\u0169."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 1285922619873297232, guid: 38c26bda4219e7644acf35f8da6fda56, type: 3}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: Sigh
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "T\xE1i s\u1EA3n xu\u1EA5t gi\u1EA3n \u0111\u01A1n kh\xF4ng ph\u1EA3i
      l\xE0 h\xECnh th\xE1i \u0111i\u1EC3n h\xECnh c\u1EE7a kinh t\u1EBF t\u01B0
      b\u1EA3n. Kinh doanh m\xE0 kh\xF4ng tr\xEDch l\u1EADp qu\u1EF9 d\u1EF1 ph\xF2ng,
      kh\xF4ng n\xE2ng c\u1EA5p thi\u1EBFt b\u1ECB th\xEC s\u1EBD b\u1ECB t\u1EE5t
      h\u1EADu v\xE0 \u0111\xE0o th\u1EA3i ngay l\u1EADp t\u1EE9c!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: 0}
      CharacterAnimTrigger: Facepalm
