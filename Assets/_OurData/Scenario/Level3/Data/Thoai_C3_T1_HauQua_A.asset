  lines:
  - speaker: {fileID: 11400000, guid: ed33b76932720524cb4a5f2fd6b50419, type: 2}
    content: "Anh/ch\u1ECB \u01A1i... em ch\xF3ng m\u1EB7t qu\xE1... h\xF4m nay em
      l\xE0m 14 ti\u1EBFng r\u1ED3i, kh\xF4ng \u0111\u01B0\u1EE3c ng\u1ED3i lu\xF4n..."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 645547100438365676, guid: b75beb49a96dd8744bcb52cd1027534e, type: 3}
      CharacterSprite: {fileID: 8228647762972188995, guid: 916ec7769fba0d54b8a2ce2ab07c7a26, type: 3}
      CharacterAnimTrigger: Dizzy
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "*R\u1EA6M!* Nam ng\u1EA5t x\u1EC9u ngay t\u1EA1i qu\u1EA7y. H\xF4m
      sau, tr\xEAn m\u1EA1ng ng\u1EADp tr\xE0n ph\u1ED1t '\xD4ng ch\u1EE7 b\xF3c
      l\u1ED9t s\u1EE9c lao \u0111\u1ED9ng sinh vi\xEAn d\xE3 man'."
    voiceClipOverride: {fileID: 0}
