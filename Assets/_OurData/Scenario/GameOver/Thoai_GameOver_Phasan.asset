  lines:
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "T\xE0i kho\u1EA3n c\u1EE7a b\u1EA1n ch\u1EC9 c\xF2n \u0111\xFAng 0
      VN\u0110. Ti\u1EC1n nh\xE0 ch\u01B0a \u0111\xF3ng, ti\u1EC1n nh\u1EADp h\xE0ng
      kh\xF4ng c\xF2n..."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 5302791405448047865, guid: 0ab07f0f5b0dad744b15eef1cfe7f265, type: 3}
      CharacterSprite: {fileID: 21300000, guid: f67a3ea10109c9c4dafc478eca3d914e, type: 2}
      CharacterAnimTrigger: 
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "Kinh doanh m\xE0 \u0111\u1EC3 c\u1EE5t v\u1ED1n th\xEC coi nh\u01B0
      xong r\u1ED3i em \u1EA1. V\u1EC1 qu\xEA ch\u0103n b\xF2 th\xF4i!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
