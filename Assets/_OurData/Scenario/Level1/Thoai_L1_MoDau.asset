  lines:
  - speaker: {fileID: 11400000, guid: 8fd1a3487fca49e4c8142d903489c55b, type: 2}
    content: "Level 1: Kh\u1EDFi nghi\u1EC7p & H\xE0ng h\xF3a. B\u1EA1n v\u1EEBa
      vay b\u1ED1 m\u1EB9 5 tri\u1EC7u \u0111\u1EC3 m\u1EDF xe b\xE1nh m\xEC tr\u01B0\u1EDBc
      c\u1ED5ng FPTU. B\u1EA1n c\u1EA7n quy\u1EBFt \u0111\u1ECBnh s\u1EA3n ph\u1EA9m
      \u0111\u1EA7u ti\xEAn."
    voiceClipOverride: {fileID: 0}
  - speaker: {fileID: 11400000, guid: 3d2603d1e748bf84480dc4ddea1d28aa, type: 2}
    content: "Ch\xE0o t\xE2n ch\u1EE7 t\u1ECBch! \u0110\u1EC3 b\u1EAFt \u0111\u1EA7u,
      c\u1EADu \u0111\u1ECBnh b\xE1n lo\u1EA1i b\xE1nh m\xEC n\xE0o \u0111\u1EC3
      thu h\xFAt sinh vi\xEAn nh\u1EA5t?"
    voiceClipOverride: {fileID: 0}
