  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dea60b411c9a18c4980249e287142770, type: 3}
  m_Name: Step_T2_02_CauHoi
  m_EditorClassIdentifier: Assembly-CSharp::QuestionStep
  questionText: "Chi\u1EBFn l\u01B0\u1EE3c nh\u1EADp nguy\xEAn li\u1EC7u c\u1EE7a
    T\xE2n ch\u1EE7 t\u1ECBch l\xE0 g\xEC?"
  optionA:
    text: "T\u1EF1 mua b\u1ED9t v\u1EC1 nh\xE0o n\u01B0\u1EDBng, t\u1EF1 \u01B0\u1EDBp
      th\u1ECBt, t\u1EF1 tr\u1ED3ng rau m\u1EA7m \u1EDF ban c\xF4ng ph\xF2ng tr\u1ECD!
      L\u1EA5y c\xF4ng l\xE0m l\xE3i."
    capitalChange: -200000
    brandChange: 0
    techChange: 15
    feedback: "B\u1EA1n th\u1EE9c tr\u1EAFng 3 \u0111\xEAm nh\xE0o b\u1ED9t \u0111\u1EBFn
      vi\xEAm c\u01A1 tay. B\xE1nh c\xE1i to c\xE1i nh\u1ECF, n\u01B0\u1EDBng kh\xE9t
      l\u1EB9t. B\u1EA1n ki\u1EC7t s\u1EE9c, l\u1EE1 m\u1EA5t ng\xE0y khai tr\u01B0\u01A1ng."
    nextBranch: {fileID: 11400000, guid: cdf5d10c51581394d88fe36d5ea6af5b, type: 2}
  optionB:
    text: "Ch\u1EA5p nh\u1EADn \u0111au v\xED! K\xFD h\u1EE3p \u0111\u1ED3ng v\u1EDBi
      l\xF2 b\xE1nh m\xEC ngon nh\u1EA5t, d\u1EADy t\u1EEB 4h s\xE1ng ra ch\u1EE3
      \u0111\u1EA7u m\u1ED1i nh\u1EB7t t\u1EEBng m\u1EDB rau."
    capitalChange: -1500000
    brandChange: 20
    techChange: 5
    feedback: "4h s\xE1ng l\u1EA1nh c\u1EAFt da c\u1EAFt th\u1ECBt, ti\u1EC1n v\u1ED1n
      v\u01A1i \u0111i x\xF3t xa. Nh\u01B0ng \u0111\u1ED5i l\u1EA1i, m\u1EBB b\xE1nh
      m\xEC \u0111\u1EA7u ti\xEAn ra l\xF2 th\u01A1m n\u1EE9c m\u0169i, an to\xE0n
      tuy\u1EC7t \u0111\u1ED1i."
    nextBranch: {fileID: 0}
  optionC:
    text: "Mua l\u1EA1i b\xE1nh m\xEC \u1EBF c\u1EE7a ti\u1EC7m t\u1EA1p h\xF3a,
      x\u1ECBt n\u01B0\u1EDBc n\u01B0\u1EDBng l\u1EA1i. Tr\u1ED9n th\xEAm th\u1ECBt
      \u0111\xF4ng l\u1EA1nh c\u1EADn date cho r\u1EBB."
    capitalChange: 800000
    brandChange: -50
    techChange: -5
    feedback: "Doanh thu ng\xE0y \u0111\u1EA7u ch\xF3t v\xF3t nh\u1EDD chi ph\xED
      si\xEAu r\u1EBB! Nh\u01B0ng s\xE1ng h\xF4m sau, group 'FPTU Confessions' ng\u1EADp
      tr\xE0n b\xE0i ph\u1ED1t T\xE0o Th\xE1o r\u01B0\u1EE3t."
    nextBranch: {fileID: 11400000, guid: 680b0c5b62bff2d4e94b190c9bc4effa, type: 2}
