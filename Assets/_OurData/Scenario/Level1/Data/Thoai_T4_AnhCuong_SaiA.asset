  m_Script: {fileID: 11500000, guid: e2eab4a3faaa6134d89cbb71d1d5a509, type: 3}
  m_Name: Thoai_T4_AnhCuong_SaiA
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "Ng\u1ED1c \u1EA1! L\u01B0\u1EE3ng gi\xE1 tr\u1ECB h\xE0ng h\xF3a \u0111\u01B0\u1EE3c
      \u0111o b\u1EB1ng 'Th\u1EDDi gian lao \u0111\u1ED9ng x\xE3 h\u1ED9i c\u1EA7n
      thi\u1EBFt', ch\u1EE9 kh\xF4ng ph\u1EA3i th\u1EDDi gian lao \u0111\u1ED9ng
      c\xE1 bi\u1EC7t c\u1EE7a em!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: -1780644666720818765, guid: c652ccbc3f57ef049a0f6582766166ce, type: 3}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: 
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "N\xF3 ph\u1EE5 thu\u1ED9c v\xE0o tr\xECnh \u0111\u1ED9 k\u1EF9 thu\u1EADt
      trung b\xECnh c\u1EE7a x\xE3 h\u1ED9i. Em l\xE0m ch\u1EADm l\xE0 do em y\u1EBFu
      k\xE9m, th\u1ECB tr\u01B0\u1EDDng kh\xF4ng c\xF3 ngh\u0129a v\u1EE5 ph\u1EA3i
      tr\u1EA3 ti\u1EC1n cho s\u1EF1 l\xF3ng ng\xF3ng c\u1EE7a em. B\xE1n gi\xE1
      tr\xEAn tr\u1EDDi ai m\xE0 mua!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: Shake
