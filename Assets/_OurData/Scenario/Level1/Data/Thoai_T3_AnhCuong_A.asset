  lines:
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "\u1EBE kh\xE1ch r\u1ED3i ph\u1EA3i kh\xF4ng? Em \u0111ang sa \u0111\xE0
      v\xE0o 'Lao \u0111\u1ED9ng c\u1EE5 th\u1EC3' \u0111\u1EC3 t\u1EA1o ra 'Gi\xE1
      tr\u1ECB s\u1EED d\u1EE5ng' \u0111\u1EB9p \u0111\u1EBD..."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: Sigh
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "Nh\u01B0ng em qu\xEAn m\u1EA5t 'Lao \u0111\u1ED9ng tr\u1EEBu t\u01B0\u1EE3ng'
      - s\u1EF1 hao ph\xED s\u1EE9c lao \u0111\u1ED9ng \u0111\u1EC3 t\u1EA1o ra 'Gi\xE1
      tr\u1ECB' trao \u0111\u1ED5i. L\xE0m qu\xE1 l\xE2u khi\u1EBFn chi ph\xED th\u1EDDi
      gian t\u0103ng, s\u1ED1 l\u01B0\u1EE3ng b\xE1n ra \xEDt, l\xE0m sao c\xF3 l\u1EDDi?"
    voiceClipOverride: {fileID: 0}
