  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "Cu\u1ED1i c\xF9ng c\u0169ng v\xE3n kh\xE1ch. Gi\u1EDD l\xE0 l\xFAc
      t\xEDnh to\xE1n s\u1ED5 s\xE1ch. M\xECnh m\u1EDBi v\xE0o ngh\u1EC1, l\xE0m
      1 \u1ED5 b\xE1nh m\xEC m\u1EA5t t\u1EADn 15 ph\xFAt, trong khi c\xE1c c\xF4
      ch\xFA b\xE1n l\xE2u n\u0103m ch\u1EC9 m\u1EA5t 5 ph\xFAt..."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: -1780644666720818765, guid: c652ccbc3f57ef049a0f6582766166ce, type: 3}
      CharacterSprite: {fileID: -6659295376548932696, guid: 8e78461457556a84d953e95aa7aff05f, type: 3}
      CharacterAnimTrigger: 
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "T\xEDnh ra m\xECnh t\u1ED1n nhi\u1EC1u m\u1ED3 h\xF4i c\xF4ng s\u1EE9c
      g\u1EA5p 3 l\u1EA7n ng\u01B0\u1EDDi ta. V\u1EADy m\xECnh n\xEAn \u0111\u1ECBnh
      gi\xE1 \u1ED5 b\xE1nh m\xEC n\xE0y bao nhi\xEAu \u0111\u1EC3 thu h\u1ED3i v\u1ED1n
      cho x\u1EE9ng \u0111\xE1ng \u0111\xE2y?"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: -6659295376548932696, guid: 8e78461457556a84d953e95aa7aff05f, type: 3}
