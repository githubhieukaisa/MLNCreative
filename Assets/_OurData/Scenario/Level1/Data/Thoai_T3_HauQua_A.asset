  lines:
  - speaker: {fileID: 11400000, guid: 0c37e6cb641e1b34ab194c32a77957ce, type: 2}
    content: "Oa! C\u1EE7 c\u1EA3i t\u1EC9a hoa sen \u0111\u1EB9p qu\xE1! Ph\u1EA3i
      ch\u1EE5p up story ngay m\u1EDBi \u0111\u01B0\u1EE3c!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: -6457970801446557378, guid: 8c4a3ff07e48b3e4d856cf6f653a70b6, type: 3}
      CharacterAnimTrigger: Bounce
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "C\u1EA3m \u01A1n b\u1EA1n... \u1EDA k\xECa, c\xE1c b\u1EA1n ph\xEDa
      sau \u0111i \u0111\xE2u h\u1EBFt r\u1ED3i?"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: 6521387171199294658, guid: 3292b8b760bb73344bff8c77f7cf1f82, type: 3}
      CharacterAnimTrigger: 
  - speaker: {fileID: 11400000, guid: 533677378c422a24cb133d160da45f3d, type: 2}
    content: "\u0110\u1EE3i 30 ph\xFAt ch\u01B0a \u0111\u01B0\u1EE3c \u1ED5 b\xE1nh
      m\xEC! Th\xF4i d\u1EB9p \u0111i, t\xF4i tr\u1EC5 m\xF4n Tri\u1EBFt h\u1ECDc
      r\u1ED3i!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
