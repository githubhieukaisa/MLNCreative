  m_Script: {fileID: 11500000, guid: e2eab4a3faaa6134d89cbb71d1d5a509, type: 3}
  m_Name: Thoai_T4_AnhCuong_SaiC
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "T\u1ED1i v\u1EC1 ki\u1EC3m k\xEA l\u1EA1i, b\u1EA1n b\xE0ng ho\xE0ng
      nh\u1EADn ra m\xECnh \u0111\xE3 l\u1ED7 v\u1ED1n n\u1EB7ng, th\u1EADm ch\xED
      kh\xF4ng \u0111\u1EE7 ti\u1EC1n mua nguy\xEAn li\u1EC7u cho ng\xE0y mai."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: -7372406222712569488, guid: 0d23c680a76b9964c82da5bd5cd7e36a, type: 3}
      CharacterSprite: {fileID: 7566863766233733025, guid: 119caf2d917709c4e8558ba73d0b7902, type: 3}
      CharacterAnimTrigger: Shock
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "B\xE1n h\xE0ng th\u1EA5p h\u01A1n hao ph\xED lao \u0111\u1ED9ng x\xE3
      h\u1ED9i m\xE0 kh\xF4ng c\xF3 c\xF4ng ngh\u1EC7 l\xF5i th\xEC ph\xE1 s\u1EA3n
      s\u1EDBm. Em vi ph\u1EA1m quy lu\u1EADt gi\xE1 tr\u1ECB r\u1ED3i. Mu\u1ED1n
      b\xE1n r\u1EBB th\xEC Tech c\u1EE7a em ph\u1EA3i cao \u0111\u1EC3 gi\u1EA3m
      chi ph\xED, ch\u1EE9 kh\xF4ng ph\u1EA3i l\u1EA5y m\xE1u m\xECnh ra c\u1EAFt!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: Sigh
