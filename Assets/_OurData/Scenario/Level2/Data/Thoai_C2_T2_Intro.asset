  lines:
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "C\xE1i g\xEC? Gi\xE1 th\u1ECBt l\u1EE3n s\u1EC9 h\xF4m nay t\u0103ng
      g\u1EA5p \u0111\xF4i \xE1 c\xF4? \u0110\u1EA1i d\u1ECBch t\u1EA3 l\u1EE3n ch\xE2u
      Phi l\xE0m khan hi\u1EBFm ngu\u1ED3n cung \u0111\u1EBFn m\u1EE9c n\xE0y sao?"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 3343200008110861922, guid: 568a8c7783901e14cbbab764f9de20f5, type: 3}
      CharacterSprite: {fileID: -6659295376548932696, guid: 8e78461457556a84d953e95aa7aff05f, type: 3}
      CharacterAnimTrigger: 
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "Ch\u1EBFt d\u1EDF r\u1ED3i, chi ph\xED l\xE0m ra 1 \u1ED5 b\xE1nh m\xEC
      th\u1ECBt b\u1ECB \u0111\u1ED9i l\xEAn t\u1EADn n\xF3c. B\xE1n 15k nh\u01B0
      c\u0169 th\xEC l\u1ED7 v\u1ED1n s\u1EADp ti\u1EC7m m\u1EA5t. Ph\u1EA3i x\u1EED
      l\xFD b\xE0i to\xE1n n\xE0y ra sao \u0111\xE2y?"
