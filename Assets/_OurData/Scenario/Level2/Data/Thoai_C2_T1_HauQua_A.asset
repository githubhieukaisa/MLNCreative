  m_Script: {fileID: 11500000, guid: e2eab4a3faaa6134d89cbb71d1d5a509, type: 3}
  m_Name: Thoai_C2_T1_HauQua_A
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "T\xE1ch! T\xE1ch! B\u1EE9c \u1EA3nh b\u1EA1n \u0111\u1ED5 m\u1EAFm
      t\xF4m b\u1ECB \u0111\u01B0a l\xEAn confession. Ban qu\u1EA3n l\xFD \u0111\xF4
      th\u1ECB ph\u1EA1t b\u1EA1n m\u1ED9t s\u1ED1 ti\u1EC1n l\u1EDBn v\xEC g\xE2y
      r\u1ED1i."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 7113465700751713747, guid: 56e075838f42c984587f7b139d97e9d6, type: 3}
      CharacterSprite: {fileID: 8349020661681891471, guid: 2683c9ee3d507e343b6c36313d0d797c, type: 3}
      CharacterAnimTrigger: Flash
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "D\u1EEBng l\u1EA1i ngay! Em \u0111ang ph\u01A1i b\xE0y 'khuy\u1EBFt
      t\u1EADt c\u1EE7a n\u1EC1n kinh t\u1EBF th\u1ECB tr\u01B0\u1EDDng' r\u1ED3i
      \u0111\u1EA5y. C\u1EA1nh tranh l\xE0 t\u1EA5t y\u1EBFu kh\xE1ch quan, ganh
      \u0111ua nhau l\xE0 b\xECnh th\u01B0\u1EDDng..."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: -6996199402916270438, guid: 76587dac88153cf419909fc6f529b323, type: 3}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: Shake
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "Nh\u01B0ng h\xE0nh \u0111\u1ED9ng b\u1EA9n th\u1EC9u c\u1EE7a em ph\xE1
      ho\u1EA1i m\xF4i tr\u01B0\u1EDDng x\xE3 h\u1ED9i. Kinh t\u1EBF th\u1ECB tr\u01B0\u1EDDng
      \u0111\xF2i h\u1ECFi c\u1EA1nh tranh b\u1EB1ng n\u0103ng l\u1EF1c, b\u1EB1ng
      gi\xE1 tr\u1ECB th\u1EF1c, ch\u1EE9 kh\xF4ng ph\u1EA3i b\u1EB1ng th\u1EE7 \u0111o\u1EA1n
      tri\u1EC7t h\u1EA1!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: 0}
      CharacterAnimTrigger: Shake
