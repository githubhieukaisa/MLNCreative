  lines:
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "R\u1EA6M R\u1EA6M! Ti\u1EBFng \u0111\u1EADp c\u1EEDa ch\xE1t ch\xFAa.
      B\xE0 ch\u1EE7 tr\u1ECD \u0111\u1EE9ng ch\u1ED1ng n\u1EA1nh: 'Th\xE1ng n\xE0y
      tr\u1EC5 ti\u1EC1n nh\xE0 5 ng\xE0y r\u1ED3i nh\xE9! B\xE1n \u0111\u1EAFt h\xE0ng
      th\u1EBF m\xE0 \u0111\u1ECBnh x\xF9 b\xE0 \xE0?'"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 5966115473096912085, guid: 66397008ca7700d4c90927bb498cffab, type: 3}
      CharacterSprite: {fileID: 3087523885063432196, guid: c7a5afe2d115bda4bb398c7920a3e589, type: 3}
      CharacterAnimTrigger: Shake
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "D\u1EA1 con... con b\xE1n l\u1ED7 v\u1ED1n l\u1EA5y t\u01B0\u01A1ng
      t\xE1c c\xF4 \u01A1i. Gi\u1EDD con kh\xF4ng c\xF2n xu n\xE0o..."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
