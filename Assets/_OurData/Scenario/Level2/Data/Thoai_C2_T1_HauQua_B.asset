  m_Script: {fileID: 11500000, guid: e2eab4a3faaa6134d89cbb71d1d5a509, type: 3}
  m_Name: Thoai_C2_T1_HauQua_B
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "Tr\u1EDDi \u01A1i, l\xE0m kh\xF4ng ng\u01A1i tay m\xE0 cu\u1ED1i th\xE1ng
      m\u1EDF v\xED ra kh\xF4ng c\xF2n \u0111\u1ED3ng n\xE0o \u0111\u1EC3 nh\u1EADp
      h\xE0ng cho ng\xE0y mai. S\u1EAFp ph\xE1 s\u1EA3n r\u1ED3i!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: -6996199402916270438, guid: 76587dac88153cf419909fc6f529b323, type: 3}
      CharacterSprite: {fileID: 5703871548070424986, guid: 8039e3c904124844590a3184b89e5bae, type: 3}
      CharacterAnimTrigger: Drop
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "Em l\u1EA1i qu\xEAn b\xE0i r\u1ED3i. 'Quy lu\u1EADt c\u1EA1nh tranh'
      y\xEAu c\u1EA7u c\xE1c ch\u1EE7 th\u1EC3 ph\u1EA3i ganh \u0111ua nh\u01B0ng
      ph\u1EA3i xoay quanh 'Quy lu\u1EADt gi\xE1 tr\u1ECB'!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: Sigh
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "T\xE1c \u0111\u1ED9ng c\u1EE7a quy lu\u1EADt gi\xE1 tr\u1ECB l\xE0
      k\xEDch th\xEDch c\u1EA3i ti\u1EBFn k\u1EF9 thu\u1EADt, h\u1EE3p l\xFD h\xF3a
      s\u1EA3n xu\u1EA5t. Ch\u1EE9 em b\xE1n d\u01B0\u1EDBi m\u1EE9c gi\xE1 tr\u1ECB
      th\u1EF1c t\u1EBF qu\xE1 l\xE2u \u0111\u1EC3 gi\xE0nh gi\u1EADt kh\xE1ch th\xEC
      em \u0111ang t\u1EF1 s\xE1t. T\u1EC9nh t\xE1o l\u1EA1i v\xE0 \u0111\u1ED5i
      chi\u1EBFn thu\u1EADt ngay!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: 
