  lines:
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "L\u01B0\u1EDBi \u0111i\u1EC7n khu tr\u1ECD b\u1ECB qu\xE1 t\u1EA3i
      do nhi\u1EC1u ng\u01B0\u1EDDi c\u1EAFm t\u1EE7 \u0111\xF4ng. T\u1EE7 th\u1ECBt
      c\u1EE7a b\u1EA1n b\u1ECB ng\u1EAFt \u0111i\u1EC7n 2 ng\xE0y r\u01B0\u1EE1i."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: -5540367852387230924, guid: abd003746ad99764abf0b887db93f984, type: 3}
      CharacterSprite: {fileID: -5234017553378999613, guid: 5cdb1f9ff830e654a8dec1cb9a753126, type: 3}
      CharacterAnimTrigger: 
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "\xD4i th\xF4i h\u1ECFng h\u1EBFt th\u1ECBt r\u1ED3i! C\xF9ng l\xFAc
      \u0111\xF3 nh\xE0 n\u01B0\u1EDBc x\u1EA3 kho d\u1EF1 tr\u1EEF b\xECnh \u1ED5n
      gi\xE1. Gi\xE1 l\u1EE3n quay \u0111\u1EA7u gi\u1EA3m s\xE2u. Th\u1EBF l\xE0
      \xF4m tr\u1ECDn c\u1EE5c n\u1EE3 t\xEDn d\u1EE5ng \u0111en!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: 0}
      CharacterAnimTrigger: Tremble
