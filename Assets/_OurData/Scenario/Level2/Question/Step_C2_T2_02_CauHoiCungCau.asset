--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dea60b411c9a18c4980249e287142770, type: 3}
  m_Name: Step_C2_T2_02_CauHoiCungCau
  m_EditorClassIdentifier: Assembly-CSharp::QuestionStep
  questionText: "Ngu\u1ED3n cung gi\u1EA3m m\u1EA1nh, gi\xE1 nguy\xEAn li\u1EC7u
    t\u0103ng phi m\xE3. T\xE2n ch\u1EE7 t\u1ECBch ch\u1ED1t ph\u01B0\u01A1ng \xE1n
    n\xE0o?"
  optionA:
    text: "Vay n\u1EB7ng l\xE3i gom s\u1EA1ch th\u1ECBt l\u1EE3n \u1EDF ch\u1EE3
      \u0111\u1EC3 \u0111\u1EA7u c\u01A1 t\xEDch tr\u1EEF, ch\u1EDD gi\xE1 l\xEAn
      \u0111\u1EC9nh \u0111i\u1EC3m th\xEC b\xE1n l\u1EA1i ki\u1EBFm l\u1EDDi (\u0110\u1EA7u
      c\u01A1 tr\u1EE5c l\u1EE3i)."
    capitalChange: -3000000
    brandChange: -50
    techChange: 0
    feedback: "B\u1EA1n vay n\xF3ng mua \u0111\u1EE9t 2 t\u1EE7 \u0111\xF4ng th\u1ECBt
      l\u1EE3n. V\xE0i ng\xE0y \u0111\u1EA7u, gi\xE1 th\u1ECBt ti\u1EBFp t\u1EE5c
      v\u1ECDt l\xEAn, b\u1EA1n \u0111\u1EAFc \xFD t\u01B0\u1EDFng ch\u1EEBng s\u1EAFp
      th\xE0nh t\u1EF7 ph\xFA. Nh\u01B0ng \u0111\u1EDDi kh\xF4ng nh\u01B0 m\u01A1..."
    nextBranch: {fileID: 11400000, guid: 5d678aa831220ce4aa3326f134f96a67, type: 2}
  optionB:
    text: "Gi\u1EEF nguy\xEAn menu, g\u1ED3ng m\xECnh gi\u1EEF nguy\xEAn gi\xE1 b\xE1n
      c\u0169 15k/\u1ED5 v\xEC s\u1EE3 m\u1EA5t l\xF2ng sinh vi\xEAn, ch\u1EA5p nh\u1EADn
      b\xE1n l\u1ED7 5k/\u1ED5."
    capitalChange: -2500000
    brandChange: 60
    techChange: 0
    feedback: "T\u1EA5t c\u1EA3 c\xE1c h\xE0ng qu\xE1n kh\xE1c \u0111\u1EC1u t\u0103ng
      gi\xE1, ri\xEAng b\u1EA1n gi\u1EEF nguy\xEAn. Sinh vi\xEAn phong b\u1EA1n l\xE0m
      \"B\u1ED3 t\xE1t s\u1ED1ng\", kh\xE1ch x\u1EBFp h\xE0ng r\u1ED3ng r\u1EAFn.
      Nh\u01B0ng b\u1EA1n \u0111ang b\xE1n m\xE1u c\u1EE7a ch\xEDnh m\xECnh..."
    nextBranch: {fileID: 11400000, guid: c117b1bf04e6bec4096b4cc6d88e5a78, type: 2}
  optionC:
    text: "Thu\u1EADn theo th\u1ECB tr\u01B0\u1EDDng: T\u0103ng gi\xE1 b\xE1nh m\xEC
      th\u1ECBt l\xEAn 20k/\u1ED5, tung th\xEAm m\xF3n m\u1EDBi B\xE1nh m\xEC Tr\u1EE9ng
      X\xFAc X\xEDch 15k \u0111\u1EC3 c\xF3 l\u1EF1a ch\u1ECDn thay th\u1EBF."
    capitalChange: 1500000
    brandChange: -10
    techChange: 20
    feedback: "M\u1ED9t v\xE0i kh\xE1ch than phi\u1EC1n gi\xE1 t\u0103ng, nh\u01B0ng
      h\u1ECD nhanh ch\xF3ng hi\u1EC3u ra t\xECnh h\xECnh chung. Nh\u1EEFng ng\u01B0\u1EDDi
      ti\u1EBFt ki\u1EC7m vui v\u1EBB chuy\u1EC3n sang \u0103n b\xE1nh m\xEC tr\u1EE9ng.
      B\u1EA1n gi\u1EEF \u0111\u01B0\u1EE3c bi\xEAn \u0111\u1ED9 l\u1EE3i nhu\u1EADn
      v\xE0 m\u1EDF r\u1ED9ng menu!"
    nextBranch: {fileID: 0}
