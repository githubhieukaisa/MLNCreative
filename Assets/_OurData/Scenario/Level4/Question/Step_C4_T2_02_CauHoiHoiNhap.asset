  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dea60b411c9a18c4980249e287142770, type: 3}
  m_Name: Step_C4_T2_02_CauHoiHoiNhap
  m_EditorClassIdentifier: Assembly-CSharp::QuestionStep
  questionText: "T\u1EADp \u0111o\xE0n \u0111a qu\u1ED1c gia t\u1EA5n c\xF4ng, qu\u1EF9
    ngo\u1EA1i mu\u1ED1n mua \u0111\u1EE9t th\u01B0\u01A1ng hi\u1EC7u. B\u1EA1n ph\u1EA3i
    l\xE0m g\xEC trong c\u01A1n l\u1ED1c To\xE0n c\u1EA7u h\xF3a n\xE0y?"
  optionA:
    text: "'B\u1EBF quan t\u1ECFa c\u1EA3ng': \u0110\u0103ng b\xE0i m\u1EA1ng x\xE3
      h\u1ED9i k\xEAu g\u1ECDi t\u1EA9y chay \u0111\u1ED3 \u0103n ngo\u1EA1i, c\u1EA5m
      nh\xE2n vi\xEAn giao ti\u1EBFp ti\u1EBFng Anh v\u1EDBi kh\xE1ch T\xE2y (Ch\u1ED1ng
      l\u1EA1i h\u1ED9i nh\u1EADp)."
    capitalChange: 0
    brandChange: -60
    techChange: -20
    feedback: "B\u1EA1n b\u1EA3o v\u1EC7 \u0111\u01B0\u1EE3c 's\u1EF1 thu\u1EA7n
      Vi\u1EC7t' trong l\xF2ng m\u1ED9t v\xE0i ng\u01B0\u1EDDi c\u1EF1c \u0111oan.
      Nh\u01B0ng \u0111a s\u1ED1 kh\xE1ch h\xE0ng quay l\u01B0ng v\xEC s\u1EF1 c\u1ED5
      h\u1EE7 v\xE0 b\xE0i ngo\u1EA1i c\u1EE7a b\u1EA1n."
    nextBranch: {fileID: 11400000, guid: 94397d18e8ba0024ab18f93a8f9692a8, type: 2}
  optionB:
    text: "'B\xE1n m\xECnh': \u0110\u1ED3ng \xFD b\xE1n \u0111\u1EE9t th\u01B0\u01A1ng
      hi\u1EC7u v\xE0 c\xF4ng th\u1EE9c cho qu\u1EF9 n\u01B0\u1EDBc ngo\xE0i, nh\u1EADn
      ngay 1 c\u1EE5c ti\u1EC1n kh\u1ED5ng l\u1ED3 r\u1ED3i l\xE0m thu\xEA l\u1EA1i
      cho ch\xEDnh h\u1ECD."
    capitalChange: 10000000
    brandChange: -100
    techChange: 0
    feedback: "B\xD9M! T\xE0i kho\u1EA3n c\u1ED9ng 10 tri\u1EC7u! B\u1EA1n s\u01B0\u1EDBng
      r\u01A1n ng\u01B0\u1EDDi v\xEC t\u1EF1 nhi\xEAn gi\xE0u to. Nh\u01B0ng ni\u1EC1m
      vui ng\u1EAFn ch\u1EB3ng t\xE0y gang..."
    nextBranch: {fileID: 11400000, guid: 23438532302fbf14f934450f7fcf5811, type: 2}
  optionC:
    text: "'Ch\u1EE7 \u0111\u1ED9ng h\u1ED9i nh\u1EADp': T\u1EEB ch\u1ED1i b\xE1n.
      Tr\xEDch ti\u1EC1n d\u1ECBch menu song ng\u1EEF, \u0111\u01B0a b\xE1nh l\xEAn
      c\xE1c app qu\u1ED1c t\u1EBF (Grab/Shopee), n\xE2ng cao ch\u1EA5t l\u01B0\u1EE3ng
      c\u1EA1nh tranh s\xF2ng ph\u1EB3ng."
    capitalChange: -1500000
    brandChange: 50
    techChange: 30
    feedback: "B\u1EA1n m\u1EA5t m\u1ED9t s\u1ED1 ti\u1EC1n l\u1EDBn \u0111\u1EC3
      l\xE0m truy\u1EC1n th\xF4ng v\xE0 n\u1ED9p chi\u1EBFt kh\u1EA5u cho App giao
      \u0111\u1ED3 \u0103n. Nh\u01B0ng \u0111\xE2y l\xE0 b\u01B0\u1EDBc \u0111i mang
      t\xEDnh l\u1ECBch s\u1EED!"
    nextBranch: {fileID: 0}
