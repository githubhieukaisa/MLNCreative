  lines:
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "\u0110em r\xE1c c\xF4ng ngh\u1EC7 v\u1EC1 d\xF9ng th\xEC kh\xF4ng g\u1ECDi
      l\xE0 'Hi\u1EC7n \u0111\u1EA1i h\xF3a' \u0111\u01B0\u1EE3c \u0111\xE2u em \u1EA1."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: -7809819526224066742, guid: c12a007151a863b4ea81c6a895c447cd, type: 3}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: Sigh
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "Hi\u1EC7n nay ch\xFAng ta \u0111ang \u1EDF C\xE1ch m\u1EA1ng c\xF4ng
      nghi\u1EC7p l\u1EA7n th\u1EE9 4 (Industry 4.0) v\u1EDBi \u0111\u1EB7c tr\u01B0ng
      l\xE0 v\u1EA1n v\u1EADt k\u1EBFt n\u1ED1i v\xE0 Big Data. Em ph\u1EA3i \u1EE9ng
      d\u1EE5ng c\xF4ng ngh\u1EC7 s\u1ED1 h\xF3a \u0111\u1ED3ng b\u1ED9, ch\u1EE9
      \u0111\u1EEBng tham r\u1EBB m\xE0 r\u01B0\u1EDBc h\u1ECDa v\xE0o th\xE2n!"
    voiceClipOverride: {fileID: 0}
