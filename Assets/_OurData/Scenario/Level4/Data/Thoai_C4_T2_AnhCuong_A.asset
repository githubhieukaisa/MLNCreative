  m_Script: {fileID: 11500000, guid: e2eab4a3faaa6134d89cbb71d1d5a509, type: 3}
  m_Name: Thoai_C4_T2_AnhCuong_A
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "C\u1EA1n l\u1EDDi v\u1EDBi em! 'H\u1ED9i nh\u1EADp kinh t\u1EBF qu\u1ED1c
      t\u1EBF' l\xE0 xu th\u1EBF kh\xE1ch quan trong b\u1ED1i c\u1EA3nh to\xE0n c\u1EA7u
      h\xF3a, kh\xF4ng m\u1ED9t qu\u1ED1c gia hay doanh nghi\u1EC7p n\xE0o c\xF3
      th\u1EC3 n\xE9 tr\xE1nh ho\u1EB7c quay l\u01B0ng \u0111\u01B0\u1EE3c."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 6128645930427288602, guid: a66007b2aa527cb4495b614e4c18e324, type: 3}
      CharacterSprite: {fileID: -217934053373611831, guid: 27ca4e0b2d0ae2643b16e6d9d8c7d525, type: 3}
      CharacterAnimTrigger: Facepalm
  - speaker: {fileID: 11400000, guid: 01ed37436cc08f844852114d42b0854a, type: 2}
    content: "Thay v\xEC s\u1EE3 h\xE3i v\xE0 k\xEAu g\u1ECDi t\u1EA9y chay, em ph\u1EA3i
      t\u1EADn d\u1EE5ng n\xF3 \u0111\u1EC3 m\u1EDF r\u1ED9ng th\u1ECB tr\u01B0\u1EDDng
      v\xE0 h\u1ECDc h\u1ECFi c\xF4ng ngh\u1EC7 c\u1EE7a h\u1ECD ch\u1EE9! S\u1EEDa
      sai ngay!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: 0}
      CharacterAnimTrigger: Shake
