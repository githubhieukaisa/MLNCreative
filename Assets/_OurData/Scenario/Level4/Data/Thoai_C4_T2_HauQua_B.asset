  lines:
  - speaker: {fileID: 11400000, guid: c5049c5e0ff317d459948ede9e91b663, type: 2}
    content: "10 tri\u1EC7u c\u01A1 \xE1? B\xE1n! B\xE1n g\u1EA5p! K\xFD xong t\xEAn
      m\xECnh l\xE0 nh\xE2n vi\xEAn t\u1EADp \u0111o\xE0n l\u1EDBn r\u1ED3i, hehe!"
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 462393889442884090, guid: 9d98ba96aed03f7499f40dd8a421016a, type: 3}
      CharacterSprite: {fileID: -1893889144324857684, guid: 79c1c58c456c35b4590d565860e073ff, type: 3}
      CharacterAnimTrigger: Bounce
  - speaker: {fileID: 11400000, guid: 2f64cf74fb297b24fbcfa21c4ebf3104, type: 2}
    content: "Sau khi l\u1EA5y \u0111\u01B0\u1EE3c c\xF4ng th\u1EE9c, t\u1EADp \u0111o\xE0n
      n\u01B0\u1EDBc ngo\xE0i thay \u0111\u1ED5i h\u01B0\u01A1ng v\u1ECB b\xE1nh
      m\xEC c\xF4ng nghi\u1EC7p d\u1EDF t\u1EC7. Doanh thu s\u1EE5t gi\u1EA3m. V\xE0
      v\xEC b\u1EA1n ch\u1EC9 l\xE0 ng\u01B0\u1EDDi l\xE0m thu\xEA, h\u1ECD th\u1EB3ng
      tay sa th\u1EA3i b\u1EA1n \u0111\u1EC3 c\u1EAFt gi\u1EA3m chi ph\xED."
    voiceClipOverride: {fileID: 0}
    lineVisualState:
      BackgroundSprite: {fileID: 0}
      CharacterSprite: {fileID: -3785891826437580157, guid: 182991304549cc74ba3c69d7dcdd50cc, type: 3}
      CharacterAnimTrigger: SlideOut
