--- !u!114 &3622121609848603720
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2704131072051685915}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8a73046514f074942a7355418e202e68, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    dialogueLines:
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "Ch\xE0o c\u1EADu nh\xF3c, ch\xE0o m\u1EEBng \u0111\xE3 \u0111\u1EBFn
        th\u1EBF gi\u1EDBi n\xE0y. Ta c\u1EA7n c\u1EADu nh\xF3c t\xECm hi\u1EC3u
        t\u1EA1i sao th\u1EBF gi\u1EDBi n\xE0y l\u1EA1i tr\u1EDF th\xE0nh nh\u01B0
        v\u1EADy."
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "H\xE3y s\u1EED d\u1EE5ng A/D \u0111\u1EC3 di chuy\u1EC3n tr\xE1i ph\u1EA3i.
        Shift \u0111\u1EC3 l\u0103n, Space \u0111\u1EC3 nh\u1EA3y. C\u1EADu c\xF3
        th\u1EC3 nh\u1EA3y k\u1EBFt h\u1EE3p b\xE1m t\u01B0\u1EDDng li\xEAn ti\u1EBFp
        3 l\u1EA7n. N\u1EBFu h\u01A1n th\xEC s\u1EBD kh\xF4ng th\u1EC3 nh\u1EA3y
        \u0111\u01B0\u1EE3c n\u1EEFa."
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "Cu\u1ED1i c\xF9ng, h\xE3y l\xE0m b\u1EA5t c\u1EE9 th\u1EE9 g\xEC c\u1EADu
        mu\u1ED1n, h\xE3y t\u1EADn h\u01B0\u1EDFng l\u1EA5y th\u1EC3 gi\u1EDBi n\xE0y."
  onDialogueEndEvent:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 1694996278777974174}
        m_TargetAssemblyTypeName: GodCtrl, Assembly-CSharp
        m_MethodName: OnDialogueFinished
        m_Mode: 1
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
          m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
          m_IntArgument: 0
          m_FloatArgument: 0
          m_StringArgument: 
          m_BoolArgument: 0
        m_CallState: 2
--- !u!114 &4431501954250446602
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2704131072051685915}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 450412329cf79ef42bbb1040b62060ad, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  isDebug: 0
  nameOfGod: Unknown
  godIcon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
  godDialogue:
  - dialogueLines:
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "Ch\xE0o c\u1EADu nh\xF3c, ch\xE0o m\u1EEBng \u0111\xE3 \u0111\u1EBFn
        th\u1EBF gi\u1EDBi n\xE0y. Ta c\u1EA7n c\u1EADu nh\xF3c t\xECm hi\u1EC3u
        t\u1EA1i sao th\u1EBF gi\u1EDBi n\xE0y l\u1EA1i tr\u1EDF th\xE0nh nh\u01B0
        v\u1EADy."
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "H\xE3y s\u1EED d\u1EE5ng A/D \u0111\u1EC3 di chuy\u1EC3n tr\xE1i ph\u1EA3i.
        Shift \u0111\u1EC3 l\u0103n, Space \u0111\u1EC3 nh\u1EA3y. C\u1EADu c\xF3
        th\u1EC3 nh\u1EA3y k\u1EBFt h\u1EE3p b\xE1m t\u01B0\u1EDDng li\xEAn ti\u1EBFp
        3 l\u1EA7n. N\u1EBFu h\u01A1n th\xEC s\u1EBD kh\xF4ng th\u1EC3 nh\u1EA3y
        \u0111\u01B0\u1EE3c n\u1EEFa."
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "Cu\u1ED1i c\xF9ng, h\xE3y l\xE0m b\u1EA5t c\u1EE9 th\u1EE9 g\xEC c\u1EADu
        mu\u1ED1n, h\xE3y t\u1EADn h\u01B0\u1EDFng l\u1EA5y th\u1EC3 gi\u1EDBi n\xE0y."
  - dialogueLines:
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "T\u1ED1t l\u1EAFm! C\u1EADu \u0111\xE3 bi\u1EBFt c\xE1ch di chuy\u1EC3n
        trong th\u1EBF gi\u1EDBi n\xE0y r\u1ED3i. B\xE2y gi\u1EDD h\xE3y th\u1EED
        ti\xEAu di\u1EC7t nh\u1EEFng sinh v\u1EADt m\u1EA1nh h\u01A1n kia \u0111i."
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "Hi v\u1ECDng c\u1EADu c\xF3 th\u1EC3 ti\xEAu di\u1EC7t \u0111\u01B0\u1EE3c
        ch\xFAng v\xE0 t\xECm ra nguy\xEAn nh\xE2n c\u1EE7a m\u1ECDi chuy\u1EC7n.
        C\xF3 l\u1EBD tr\u1EEB h\u1EAFn ta ra th\xF4i."
  - dialogueLines:
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "Tuy\u1EC7t v\u1EDDi! C\u1EADu \u0111\xE3 l\xE0m r\u1EA5t t\u1ED1t. Ta
        ngh\u0129 c\u1EADu \u0111\xE3 s\u1EB5n s\xE0ng \u0111\u1EC3 \u0111\u1ED1i
        m\u1EB7t v\u1EDBi th\u1EED th\xE1ch l\u1EDBn h\u01A1n r\u1ED3i."
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "Nh\u01B0ng h\xE0nh tr\xECnh ti\u1EBFp theo c\xF3 l\u1EBD kh\xF4ng d\u1EC5
        d\xE0ng nh\u01B0 v\u1EADy \u0111\xE2u. Kh\xF4ng ch\u1EC9 chi\u1EBFn \u0111\u1EA5u
        m\xE0 c\xF3 th\u1EC3 c\xF2n ph\u1EA3i suy ngh\u0129 v\u1EC1 s\u1EF1 th\u1EADt."
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "Nh\u01B0ng ta lu\xF4n n\xF3i. H\xE3y t\u1EADn h\u01B0\u1EDFng th\u1EBF
        gi\u1EDBi n\xE0y, v\xE0 l\xE0m b\u1EA5t c\u1EE9 \u0111i\u1EC1u g\xEC c\u1EADu
        mu\u1ED1n."
  - dialogueLines:
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "C\u1EADu \u0111\xE3 s\u1EB5n s\xE0ng \u0111\u1EC3 b\u01B0\u1EDBc v\xE0o
        th\u1EBF gi\u1EDBi th\u1EF1c ch\u01B0a? H\xE3y chu\u1EA9n b\u1ECB tinh th\u1EA7n
        v\xE0 b\u01B0\u1EDBc v\xE0o c\xE1nh c\u1ED5ng n\xE0y."
  - dialogueLines:
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "\u0110\u1EEBng n\u1EA3n l\xF2ng khi th\u1EA5t b\u1EA1i. M\u1ED7i l\u1EA7n
        ch\u1EBFt \u0111i l\xE0 m\u1ED9t l\u1EA7n h\u1ECDc h\u1ECFi \u0111\u1EC3
        tr\u1EDF n\xEAn m\u1EA1nh m\u1EBD h\u01A1n."
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "H\xE3y \u0111\u1EE9ng d\u1EADy v\xE0 ti\u1EBFp t\u1EE5c h\xE0nh tr\xECnh
        c\u1EE7a m\xECnh. Ta tin c\u1EADu s\u1EBD v\u01B0\u1EE3t qua m\u1ECDi th\u1EED
        th\xE1ch."
    - character:
        name: Unknown
        icon: {fileID: 1987480966, guid: 5b54ca8235b273a4c92a6b007e7e8397, type: 3}
      line: "Mi\u1EC5n l\xE0 ta \u1EDF \u0111\xE2y, chuy\u1EC7n g\xEC c\u0169ng c\xF3
        th\u1EC3 l\xE0m \u0111\u01B0\u1EE3c."
  trigger: {fileID: 3622121609848603720}
  isBeginDialogue: 0
